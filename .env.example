# ─── CosmoERP — Template de Variables d'environnement ────────────────────────
# Copiez en .env et remplissez vos valeurs.

# Django
SECRET_KEY=your-secret-key-here-generate-with-django-get-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de données PostgreSQL
DB_NAME=bio_cosmetic
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432
